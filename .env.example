# TELEGRAM_BOT_TOKEN
# Type: string
# Required: yes
# Default: none
# Description: BotFather token used to authenticate the Telegram bot.
TELEGRAM_BOT_TOKEN=

# CHANNEL_ID
# Type: integer
# Required: yes
# Default: none
# Description: Private Telegram channel ID to watch and repost into, normally -1001704658742.
CHANNEL_ID=-1001704658742

# TELEGRAM_API_ID / TELEGRAM_API_HASH
# Type: integer / secret string
# Required: only for the Local Bot API Docker deployment
# Description: Application credentials from my.telegram.org; never commit live values.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# TELEGRAM_BOT_API_BASE_URL / TELEGRAM_BOT_API_FILE_URL
# Type: absolute HTTP(S) URLs
# Required: no; both must be set together
# Default: Telegram cloud Bot API through python-telegram-bot
# Description: Custom internal Local Bot API endpoints. Keep empty for cloud mode.
TELEGRAM_BOT_API_BASE_URL=
TELEGRAM_BOT_API_FILE_URL=

# TELEGRAM_MEDIA_WRITE_TIMEOUT_SECONDS
# Type: positive integer
# Required: no
# Default: 300
# Description: Multipart media request write timeout, used with a custom Bot API endpoint.
TELEGRAM_MEDIA_WRITE_TIMEOUT_SECONDS=300

# DOWNLOAD_TIMEOUT_SECONDS
# Type: integer
# Required: no
# Default: 60
# Description: Per-provider HTTP timeout in seconds.
DOWNLOAD_TIMEOUT_SECONDS=60

# MAX_VIDEO_SIZE_MB
# Type: integer
# Required: no
# Default: 50
# Description: Application upload cap. Keep 50 for cloud mode; Compose uses LOCAL_MAX_VIDEO_SIZE_MB.
MAX_VIDEO_SIZE_MB=50

# LOCAL_MAX_VIDEO_SIZE_MB
# Type: positive integer
# Required: no
# Default: 1900 in Docker Compose
# Description: Safety cap for the Local Bot API deployment, below Telegram's 2000 MB limit.
LOCAL_MAX_VIDEO_SIZE_MB=1900

# PREFERRED_VIDEO_HEIGHT
# Type: positive integer
# Required: no
# Default: 720
# Description: Preferred short-edge video resolution; known variants below the minimum are rejected.
PREFERRED_VIDEO_HEIGHT=720

# MIN_VIDEO_HEIGHT
# Type: positive integer
# Required: no
# Default: 720
# Description: Shared minimum short-edge resolution for every provider.
MIN_VIDEO_HEIGHT=720

# EPORNER_PREFERRED_VIDEO_HEIGHT
# Type: positive integer
# Required: no
# Default: PREFERRED_VIDEO_HEIGHT
# Description: Optional Eporner preferred-height override.
EPORNER_PREFERRED_VIDEO_HEIGHT=720

# EPORNER_MIN_VIDEO_HEIGHT
# Type: positive integer
# Required: no
# Default: MIN_VIDEO_HEIGHT
# Description: Optional Eporner minimum-height override.
EPORNER_MIN_VIDEO_HEIGHT=720

# REJECT_UNKNOWN_VIDEO_HEIGHT
# Type: boolean
# Required: no
# Default: true
# Description: Reject variants whose resolution metadata cannot be established.
REJECT_UNKNOWN_VIDEO_HEIGHT=true

# MAX_CONCURRENT_DOWNLOADS
# Type: positive integer
# Required: no
# Default: 1
# Description: Maximum concurrent channel media-processing operations.
MAX_CONCURRENT_DOWNLOADS=1

# MIN_FREE_DISK_MB
# Type: positive integer
# Required: no
# Default: 4096
# Description: Free disk reserve retained while streaming temporary media.
MIN_FREE_DISK_MB=4096

# MEDIA_TMP_DIR
# Type: string path
# Required: no
# Default: /tmp
# Description: Disk-backed temporary media directory; Compose mounts /var/lib/xvbot/media.
MEDIA_TMP_DIR=/tmp

# DROP_PENDING_UPDATES
# Type: boolean
# Required: no
# Default: false
# Description: Set true only when intentionally discarding queued channel posts.
DROP_PENDING_UPDATES=false

# REQUEST_USER_AGENT
# Type: string
# Required: no
# Default: Mozilla/5.0 (compatible; XVBOT/1.0)
# Description: User-Agent header sent on outbound HTTP requests.
REQUEST_USER_AGENT=Mozilla/5.0 (compatible; XVBOT/1.0)

# LOG_LEVEL
# Type: string
# Required: no
# Default: INFO
# Description: Python logging level for file and systemd journal output.
LOG_LEVEL=INFO

# LOG_DIR
# Type: string path
# Required: no
# Default: /var/log/xvbot
# Description: Directory where bot.log and rotations are written.
LOG_DIR=/var/log/xvbot

# ADMIN_CHAT_ID
# Type: integer
# Required: no
# Default: none
# Description: Optional Telegram chat ID to DM when every provider fails.
ADMIN_CHAT_ID=
