# TELEGRAM_BOT_TOKEN
# Type: string
# Required: yes
# Default: none
# Description: BotFather token used to authenticate the Telegram bot.
TELEGRAM_BOT_TOKEN=8230326046:AAHRGCcNHL4tlZUVj6IsmrYCmzuQz6Q1oJo

# CHANNEL_ID
# Type: integer
# Required: yes
# Default: none
# Description: Private Telegram channel ID to watch and repost into, normally -1001704658742.
CHANNEL_ID=-1001704658742

# DOWNLOAD_TIMEOUT_SECONDS
# Type: integer
# Required: no
# Default: 60
# Description: Per-provider HTTP timeout in seconds.
DOWNLOAD_TIMEOUT_SECONDS=60

# MAX_VIDEO_SIZE_MB
# Type: integer
# Required: no
# Default: 50
# Description: Telegram sendVideo size cap in megabytes before falling back to document upload.
MAX_VIDEO_SIZE_MB=50

# PREFERRED_VIDEO_HEIGHT
# Type: positive integer
# Required: no
# Default: 720
# Description: Preferred short-edge video resolution; falls back below, then above this value.
PREFERRED_VIDEO_HEIGHT=720

# EPORNER_PREFERRED_VIDEO_HEIGHT
# Type: positive integer
# Required: no
# Default: 480
# Description: Eporner-specific non-AV1 MP4 resolution preference for inline playback.
EPORNER_PREFERRED_VIDEO_HEIGHT=480

# REQUEST_USER_AGENT
# Type: string
# Required: no
# Default: Mozilla/5.0 (compatible; XVBOT/1.0)
# Description: User-Agent header sent on outbound HTTP requests.
REQUEST_USER_AGENT=Mozilla/5.0 (compatible; XVBOT/1.0)

# LOG_LEVEL
# Type: string
# Required: no
# Default: INFO
# Description: Python logging level for file and systemd journal output.
LOG_LEVEL=INFO

# LOG_DIR
# Type: string path
# Required: no
# Default: /var/log/xvbot
# Description: Directory where bot.log and rotations are written.
LOG_DIR=/var/log/xvbot

# ADMIN_CHAT_ID
# Type: integer
# Required: no
# Default: none
# Description: Optional Telegram chat ID to DM when every provider fails.
ADMIN_CHAT_ID=
